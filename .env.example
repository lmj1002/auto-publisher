# ===========================================
# 自媒体自动化发布系统 - 环境变量配置
# 复制此文件为 .env 并填入你的配置
# ===========================================

# ---- 数据库配置 ----
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=auto_publisher

# ---- Google Gemini API Key ----
# 申请地址: https://aistudio.google.com/
GEMINI_API_KEY=

# ---- Claude Code 配置 ----
# Claude Code CLI 工作目录（你的项目目录）
CLAUDE_CODE_WORK_DIR=F:\study

# ---- 知乎 Cookie（用于自动发布） ----
# 从浏览器开发者工具中复制登录后的完整 Cookie 字符串
# 也可放在项目根目录的 zhihu.cookie 文件中
ZHIHU_COOKIE=

# ---- 小红书 Cookie（用于自动发布） ----
# 从浏览器开发者工具中复制登录后的完整 Cookie 字符串
# 也可放在项目根目录的 xiaohongshu.cookie 文件中
XHS_COOKIE=

# ---- 服务器配置 ----
SERVER_PORT=8080
